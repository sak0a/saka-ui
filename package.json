{
  "name": "@sakoa/ui",
  "version": "0.2.7",
  "type": "module",
  "main": "./dist/saka-ui.umd.cjs",
  "module": "./dist/saka-ui.js",
  "types": "./dist/index.d.ts",
  "author": "sakoa",
  "bin": {
    "saka-ui": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/saka-ui.js",
      "require": "./dist/saka-ui.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "registry"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build && tsx scripts/build-registry.ts",
    "build:lib": "vite build",
    "build:lib:bundle": "vite build --mode ci-bundle",
    "build:pages": "vite build --mode pages",
    "build:registry": "tsx scripts/build-registry.ts",
    "build:cli": "tsup",
    "build:all": "vite build && tsx scripts/build-registry.ts && tsup",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview",
    "test:smoke": "node dist/cli/index.js --version && node dist/cli/index.js list --help",
    "prepublishOnly": "npm run build:all"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "lucide-vue-next": "^0.577.0",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/diff": "^8.0.0",
    "@types/prompts": "^2.4.9",
    "@vicons/ionicons5": "^0.13.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/language-core": "^3.2.5",
    "commander": "^14.0.3",
    "diff": "^8.0.3",
    "fast-glob": "^3.3.3",
    "prompts": "^2.4.2",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "npm:rolldown-vite@7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vue-tsc": "^3.2.5"
  }
}
